{
  "KbChunking": {
    "ChunkSizeChars": 2000,
    "ChunkOverlapChars": 200
  },
  "KbIngestion": {
    "SourceDirectory": ""
  },
  "KbIngestionPipeline": {
    "MaxConcurrentEmbeddings": 3,
    "RetryCount": 1
  },
  "KbRetrieval": {
    "Mode": "hybrid",
    "TopK": 3,
    "KeywordWeight": 0.5,
    "VectorWeight": 0.5,
    "CitationCount": 3
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
