{
  "KbChunking": {
    "ChunkSizeChars": 2000,
    "ChunkOverlapChars": 200
  },
  "KbIngestion": {
    "SourceDirectory": ""
  },
  "KbIngestionPipeline": {
    "MaxConcurrentEmbeddings": 3,
    "RetryCount": 1
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
