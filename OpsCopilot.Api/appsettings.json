{
  "KbChunking": {
    "ChunkSizeChars": 1200,
    "ChunkOverlapChars": 200
  },
  "KbIngestion": {
    "SourceDirectory": ""
  },
  "KbIngestionPipeline": {
    "MaxConcurrentEmbeddings": 3,
    "RetryCount": 1
  },
  "KbRetrieval": {
    "Mode": "vector",
    "TopK": 3,
    "KeywordWeight": 0.5,
    "VectorWeight": 0.5,
    "CitationCount": 3
  },
  "LogSearch": {
    "FixturesDirectory": "../fixtures/logs",
    "MaxTimeRangeHours": 24,
    "MaxResults": 50,
    "MaxQueryLength": 200
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
